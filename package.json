{
  "name": "noxvoice",
  "version": "1.0.0",
  "description": "NoxVoice voice chat app",
  "main": "main.js",
  "scripts": {
    "start": "node server.js",
    "electron": "electron .",
    "dist": "electron-builder"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "dotenv": "^17.4.2",
    "electron-updater": "^6.3.9",
    "express": "^4.18.2",
    "express-session": "^1.18.1",
    "mongoose": "^9.7.1",
    "socket.io": "^4.7.5"
  },
  "devDependencies": {
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.noxvoice.app",
    "productName": "NoxVoice",
    "directories": {
      "buildResources": "build"
    },
    "win": {
      "target": "nsis",
      "icon": "build/nox.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
